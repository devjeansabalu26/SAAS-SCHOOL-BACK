{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",

    "target": "ES2023",
    "lib": ["ES2023"],

    "outDir": "./dist",
    "baseUrl": "./",

    "declaration": true,
    "sourceMap": true,
    "incremental": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "strict": true,
    "strictNullChecks": true,

    "skipLibCheck": true,

    "types": ["node"],

    "forceConsistentCasingInFileNames": true
  }
}